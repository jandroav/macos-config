[gpg]
	format = ssh
[user]
	signingkey = /Users/jandro/.ssh/id_ed25519.pub
	name = Alejandro Alvarez
	email = avazquez@liquibase.com
[commit]
	gpgsign = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[fetch]
	prune = true
	fsckObjects = true
[rebase]
	autoStash = true
[rerere]
	enabled = true
[core]
	excludesfile = /Users/jandro/.gitignore_global
	autocrlf = input
	editor = code --wait
[diff]
	colorMoved = default
[transfer]
	fsckObjects = true
[receive]
	fsckObjects = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
